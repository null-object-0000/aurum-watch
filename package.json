{
  "name": "aurum-watch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0\" \"tsx watch server/index.ts\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "check": "tsc -b"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "echarts": "^5.6.0",
    "fastify": "^5.8.5",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.511.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.3",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
