PORT=8787
DATABASE_PATH=./data/aurum-watch.sqlite
REFRESH_INTERVAL_MS=30000

# OANDA real market data. Required for XAU/USD and USD/CNH.
# The backend discovers the first accessible account from this token.
OANDA_API_TOKEN=
OANDA_ENV=practice

# Preferred AU9999 source: run `python -m aktools --host 0.0.0.0 --port 8080`.
AKTOOLS_BASE_URL=http://127.0.0.1:8080
AKTOOLS_AU9999_SYMBOL=Au99.99
AKTOOLS_REFRESH_INTERVAL_MS=10000

# LLM 智能舆情分析（Option A）
# 支持 DeepSeek（推荐）/ OpenAI / Gemini 等 OpenAI-compatible API
# 留空则自动降级为关键词过滤方案
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# LLM 分析任务触发间隔（毫秒），默认 15 分钟
LLM_ANALYSIS_INTERVAL_MS=900000
